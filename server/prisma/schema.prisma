generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  name          String?
  createdAt     DateTime       @default(now())
  refreshTokens RefreshToken[]
  datasets      Dataset[]
  charts        Chart[]
}

model RefreshToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  replacedBy String?
  createdAt  DateTime  @default(now())

  @@index([userId])
}

model Dataset {
  id               String       @id @default(cuid())
  userId           String
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String
  originalFilename String
  rowCount         Int
  columnsMeta      Json
  parseErrors      Json
  createdAt        DateTime     @default(now())
  rows             DatasetRow[]
  charts           Chart[]
  insights         Insight[]

  @@index([userId, createdAt])
}

model DatasetRow {
  id        BigInt  @id @default(autoincrement())
  datasetId String
  dataset   Dataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  data      Json

  @@index([datasetId])
}

model Chart {
  id          String   @id @default(cuid())
  userId      String
  datasetId   String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dataset     Dataset  @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  name        String
  type        String
  xColumn     String
  yColumn     String?
  aggregation String
  position    Int
  createdAt   DateTime @default(now())

  @@index([userId])
}

model Insight {
  id          String   @id @default(cuid())
  datasetId   String
  dataset     Dataset  @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  kind        String
  contextHash String
  content     Json
  createdAt   DateTime @default(now())

  @@index([datasetId, contextHash])
}
