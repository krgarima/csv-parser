# Server runtime
PORT=3000
NODE_ENV=development

# Database — local Docker (docker-compose.yml exposes port 5433)
DATABASE_URL=postgresql://csv:csv@localhost:5433/csv

# Auth — generate with: openssl rand -base64 32
ACCESS_TOKEN_SECRET=replace_me_with_32_random_bytes
REFRESH_TOKEN_SECRET=replace_me_with_a_DIFFERENT_32_random_bytes
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
COOKIE_DOMAIN=
CORS_ORIGIN=http://localhost:5173

# LLM provider — change one line to swap.
# Options: gemini | mock
# Get a free Gemini key: https://aistudio.google.com/apikey
LLM_PROVIDER=gemini
LLM_API_KEY=
LLM_MODEL=

# Limits
MAX_UPLOAD_BYTES=10485760
MAX_ROWS=50000
CHART_CAP_PER_USER=3
